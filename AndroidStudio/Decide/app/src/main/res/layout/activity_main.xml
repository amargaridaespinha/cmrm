<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="#F8F9FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎲 Decide Já!"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Escolhe uma categoria"
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginBottom="24dp"/>

    <!-- Botões de categoria -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <Button
            android:id="@+id/btnFood"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🍕 Comer"
            android:layout_margin="4dp"
            android:backgroundTint="#FF6B6B"/>

        <Button
            android:id="@+id/btnWatch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎬 Ver"
            android:layout_margin="4dp"
            android:backgroundTint="#4ECDC4"/>

        <Button
            android:id="@+id/btnDo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🏃 Fazer"
            android:layout_margin="4dp"
            android:backgroundTint="#45B7D1"/>

    </LinearLayout>

    <!-- Caixa do resultado -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍕 O que comer?"
                android:textSize="16sp"
                android:textColor="#888888"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prime o botão!"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:gravity="center"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Botão principal -->
    <Button
        android:id="@+id/btnDecide"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="🎲 DECIDE!"
        android:textSize="20sp"
        android:textStyle="bold"
        android:backgroundTint="#1A1A2E"
        android:layout_marginBottom="16dp"/>

    <!-- Botão histórico -->
    <Button
        android:id="@+id/btnHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 Ver Histórico"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="#1A1A2E"/>

</LinearLayout>